{
  "expo": {
    "name": "Nimantran",
    "slug": "invitewala-test2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C0C14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nimantran.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0C0C14"
      },
      "package": "com.nimantran.app",
      "permissions": [
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Nimantran to save invitation cards to your gallery.",
          "savePhotosPermission": "Allow Nimantran to save invitation cards to your gallery."
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "8d9d03c2-ba58-4dde-b585-b1762e348a5a"
      },
      "_firebaseDisabled": {
        "reason": "Guest-only mode until Firebase Blaze plan is enabled. To re-enable: restore the plugin entries below and add googleServicesFile keys back under ios/android.",
        "iosGoogleServicesFile": "./GoogleService-Info.plist",
        "androidGoogleServicesFile": "./google-services.json",
        "plugins": [
          "@react-native-firebase/app",
          "@react-native-firebase/auth",
          ["expo-build-properties", { "android": { "extraMavenRepos": [] }, "ios": { "useFrameworks": "static" } }]
        ]
      }
    },
    "owner": "malhar-12"
  }
}
